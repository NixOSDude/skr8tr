app review-svc
  exec     /opt/sovereign-market/bin/review-svc
  port     8007
  replicas 2

  env {
    PORT 8007
    RUST_LOG info
  }

  health {
    check    GET /health 200
    interval 10s
    timeout  3s
    retries  3
  }

  scale {
    min       1
    max       4
    cpu-above 70
    cpu-below 20
  }
