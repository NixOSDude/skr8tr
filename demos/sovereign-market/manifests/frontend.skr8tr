app frontend
  exec     /opt/sovereign-market/bin/frontend-svc
  port     4200
  replicas 2

  env {
    PORT 4200
    STATIC_DIR /opt/sovereign-market/www
    RUST_LOG info
  }

  health {
    check    GET / 200
    interval 15s
    timeout  5s
    retries  3
  }

  scale {
    min       2
    max       8
    cpu-above 60
    cpu-below 10
  }
