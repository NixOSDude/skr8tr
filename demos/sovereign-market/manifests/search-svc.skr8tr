app search-svc
  exec     /opt/sovereign-market/bin/search-svc
  port     8003
  replicas 2

  env {
    PORT 8003
    RUST_LOG info
  }

  health {
    check    GET /health 200
    interval 10s
    timeout  3s
    retries  3
  }

  scale {
    min       1
    max       6
    cpu-above 65
    cpu-below 15
  }
